page {
  --bg: #0b0b09;
  --surface: #11110f;
  --card: #1c1b17;
  --card-strong: #151512;
  --border: #3a3527;
  --primary: #ffd23f;
  --primary-strong: #f59e0b;
  --danger: #ff5148;
  --text: #f8f5e7;
  --muted: #9a927d;
  --button-text: #0b0b09;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.theme-tech-green {
  --bg: #0a0d10;
  --surface: #11161b;
  --card: #1d242b;
  --card-strong: #141a20;
  --border: #2b3540;
  --primary: #20f0a0;
  --primary-strong: #0f766e;
  --danger: #ff5148;
  --text: #f8fafc;
  --muted: #8793a1;
  --button-text: #03110b;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 210, 63, 0.15), transparent 28%),
    radial-gradient(circle at 88% 10%, rgba(245, 158, 11, 0.12), transparent 24%),
    var(--bg);
}

.card {
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.28);
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--text);
}

.muted {
  color: var(--muted);
  font-size: 26rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  margin-right: 12rpx;
  margin-top: 12rpx;
  border-radius: 8rpx;
  background: var(--card-strong);
  border: 2rpx solid var(--border);
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.primary-button {
  height: 88rpx;
  border-radius: 12rpx;
  background: var(--primary);
  color: var(--button-text);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.ghost-button {
  height: 80rpx;
  border-radius: 12rpx;
  background: var(--card-strong);
  border: 2rpx solid var(--border);
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 80rpx;
}
