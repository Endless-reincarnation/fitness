.nutrition-page {
  padding: 48rpx 28rpx 40rpx;
}

.screen-header {
  margin-bottom: 28rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.page-title {
  margin-top: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.08;
}

.focus-card {
  margin-bottom: 24rpx;
  border: 3rpx solid var(--primary);
  background:
    linear-gradient(135deg, var(--primary-fade-12), transparent 58%),
    var(--card);
}

.focus-label {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.focus-text {
  margin-top: 16rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.5;
}

.weight-note {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 8rpx 14rpx;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 22rpx;
  font-weight: 900;
}

.day-type-switch {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.day-type-item {
  height: 64rpx;
  line-height: 64rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.day-type-item.active {
  border-color: var(--primary);
  color: var(--button-text);
  background: var(--primary);
}

.adjust-note {
  margin-bottom: 22rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
}

.macro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.macro-card {
  min-height: 154rpx;
  border-radius: 12rpx;
}

.macro-card.highlight {
  border-color: var(--primary);
}

.macro-value {
  display: inline;
  color: var(--text);
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.macro-unit {
  display: inline;
  margin-left: 8rpx;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.macro-label {
  margin-top: 14rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.food-card,
.next-card,
.empty-card {
  margin-bottom: 24rpx;
}

.compact-title {
  font-size: 30rpx;
}

.food-row {
  display: grid;
  grid-template-columns: 116rpx 1fr;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.food-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.food-label {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.food-text {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.5;
}

.next-row {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 18rpx;
  line-height: 1.6;
}

.profile-button {
  margin-top: 28rpx;
}
