.page {
  padding: 48rpx 28rpx 32rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.page-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.intro {
  line-height: 1.5;
}

.block {
  margin-bottom: 26rpx;
  border-radius: 12rpx;
}

.field-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.field-label.second {
  margin-top: 24rpx;
}

.small-title {
  font-size: 30rpx;
}

.profile-hint {
  margin-top: 10rpx;
  line-height: 1.5;
}

.input,
.mini-input,
.textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 78rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
}

.textarea {
  min-height: 180rpx;
  padding-top: 18rpx;
  line-height: 1.5;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.option-pill {
  padding: 16rpx 22rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.option-pill.active {
  border-color: var(--primary);
  color: var(--button-text);
  background: var(--primary);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.profile-row {
  grid-template-columns: 1fr 1fr 1fr;
  margin-top: 22rpx;
}

.field-box {
  min-width: 0;
}

.mini-input {
  text-align: center;
}

.generate-button {
  margin-top: 26rpx;
  border-radius: 10rpx;
}

.progress-backdrop {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.74);
  z-index: 300;
}

.progress-sheet {
  box-sizing: border-box;
  width: 100%;
  max-height: 78vh;
  overflow: hidden;
  padding: 30rpx;
  border: 3rpx solid var(--primary);
  border-radius: 12rpx;
  background: rgba(255, 210, 63, 0.08);
}

.progress-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.progress-title {
  margin-top: 12rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.4;
}

.progress-steps {
  margin-top: 18rpx;
}

.progress-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.progress-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.progress-preview {
  max-height: 260rpx;
  overflow: hidden;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 22rpx;
  line-height: 1.5;
}

.preview-label {
  margin-bottom: 8rpx;
  color: var(--primary);
  font-size: 20rpx;
  font-weight: 900;
}
