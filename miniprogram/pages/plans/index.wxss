.page {
  padding: 48rpx 28rpx 32rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.page-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.intro {
  line-height: 1.5;
}

.create-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 32rpx;
}

.create-button {
  margin-bottom: 32rpx;
  border-radius: 10rpx;
}

.create-actions .create-button {
  width: 100% !important;
  margin-bottom: 0;
}

.group-title {
  margin: 34rpx 0 22rpx;
  font-size: 34rpx;
}

.active-plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 30rpx;
  padding: 30rpx;
  border: 3rpx solid var(--primary);
  border-radius: 14rpx;
  background: rgba(255, 210, 63, 0.08);
}

.active-plan-title {
  margin-top: 14rpx;
  color: var(--text);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.18;
}

.active-plan-sub {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.active-plan-button {
  flex: 0 0 128rpx;
  width: 128rpx !important;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.empty-card {
  margin-bottom: 30rpx;
  padding: 30rpx;
  border: 3rpx dashed var(--border);
  border-radius: 14rpx;
  background: var(--card-strong);
}

.empty-title {
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
}

.empty-sub {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-action {
  margin-top: 22rpx;
  border-radius: 10rpx;
}

.plan-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 34rpx 0 24rpx;
  padding: 8rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card-strong);
}

.plan-tab {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 9rpx;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 900;
  text-align: center;
}

.plan-tab.active {
  color: var(--button-text);
  background: var(--primary);
}

.tab-hint {
  margin: -4rpx 0 22rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.tab-empty {
  margin-top: 4rpx;
}

.plan-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  border: 3rpx solid var(--border);
  border-radius: 14rpx;
  background: var(--card);
}

.plan-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.plan-title {
  margin-top: 18rpx;
  color: var(--text);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.plan-summary {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.5;
}

.metric-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.metric-box {
  min-height: 92rpx;
  padding: 14rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
}

.metric-label {
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 900;
}

.metric-value {
  margin-top: 10rpx;
  color: var(--text);
  font-size: 26rpx;
  font-weight: 900;
}

.tags {
  margin-top: 18rpx;
}

.plan-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.plan-action-button {
  width: 100% !important;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}
