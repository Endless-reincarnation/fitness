<view class="page theme-{{theme}}">
  <!-- 训练打卡日历 -->
  <view class="card block calendar-card">
    <view class="calendar-header">
      <view class="calendar-btn" bindtap="prevPeriod">◀</view>
      <view class="calendar-month">{{currentYear}} 年 {{currentMonth + 1}} 月</view>
      <view class="calendar-btn" bindtap="nextPeriod">▶</view>
    </view>
    
    <view class="weekday-row">
      <view wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this" class="weekday-label">{{item}}</view>
    </view>
    
    <view class="days-grid">
      <block wx:for="{{calendarGrid}}" wx:key="id">
        <view class="day-cell blank" wx:if="{{item.type === 'blank'}}"></view>
        <view class="day-cell {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.hasWorkout ? 'has-workout' : ''}}" 
              wx:else 
              bindtap="selectDate" 
              data-date="{{item.dateStr}}">
          <view class="day-num">{{item.day}}</view>
          <view class="workout-dot" wx:if="{{item.hasWorkout}}"></view>
        </view>
      </block>
    </view>

    <!-- 折叠展开切换栏 -->
    <view class="calendar-toggle" bindtap="toggleCalendarMode">
      <text>{{calendarMode === 'week' ? '展开月历' : '收起月历'}}</text>
      <text class="toggle-icon">{{calendarMode === 'week' ? '▼' : '▲'}}</text>
    </view>
  </view>

  <!-- 本周训练洞察 -->
  <view class="card block insight-card" wx:if="{{weeklyInsight}}">
    <view class="section-title">本周训练</view>
    <view class="week-progress-row">
      <view>
        <view class="week-progress-value">{{weeklyInsight.completedDays}} / {{weeklyInsight.targetDays}}</view>
        <view class="week-progress-label">完成天数</view>
      </view>
      <view class="week-progress-percent">{{weeklyInsight.progressPercent}}%</view>
    </view>
    <view class="week-bar">
      <view class="week-bar-fill" style="width: {{weeklyInsight.progressPercent}}%;"></view>
    </view>
    <view class="week-stat-grid">
      <view class="week-stat-item">
        <view class="week-stat-value">{{weeklyInsight.totalSets}}</view>
        <view class="week-stat-label">累计组数</view>
      </view>
      <view class="week-stat-item">
        <view class="week-stat-value">{{weeklyInsight.totalVolume}}</view>
        <view class="week-stat-label">累计容量 KG</view>
      </view>
    </view>
    <view class="insight-text">{{weeklyInsight.insightText}}</view>
  </view>

  <!-- 动作进步榜 -->
  <view class="card block" wx:if="{{exerciseProgressList.length}}">
    <view class="section-title">动作进步榜</view>
    <view wx:for="{{exerciseProgressList}}" wx:key="exerciseId" class="progress-row">
      <view class="progress-main">
        <view class="progress-name">{{item.exerciseName}}</view>
        <view class="progress-meta">本次 {{item.latestText}} · 上次 {{item.previousText}}</view>
      </view>
      <view class="progress-badge {{item.isUp ? 'up' : ''}} {{item.isDown ? 'down' : ''}}">{{item.trendText}}</view>
    </view>
  </view>

  <!-- 训练历史数据回溯 -->
  <block wx:if="{{latestSession}}">
    <view class="report-header block-margin">
      <view class="eyebrow">SESSION REPORT</view>
      <view class="report-title">训练表现</view>
      <view class="muted">{{latestSession.planName}} · {{latestSession.dayName}}</view>
      <view class="muted-stats">{{latestSetCount}} 组 · 总容量 {{latestTotalVolume}} kg</view>
    </view>

    <view class="next-card" wx:if="{{nextExerciseName}}">
      <view class="next-label">下次建议</view>
      <view class="next-title">{{nextExerciseName}}</view>
      <view class="next-text">{{nextAdviceText}}</view>
    </view>

    <view class="card block" wx:if="{{muscleStimulation && muscleStimulation.length}}">
      <view class="section-title">肌群刺激</view>
      <view wx:for="{{muscleStimulation}}" wx:key="name" class="muscle-row">
        <view class="muscle-header">
          <text class="muted">{{item.name}}</text>
          <text class="muscle-percent">{{item.percentage}}%</text>
        </view>
        <view class="bar">
          <view class="bar-fill" style="width: {{item.percentage}}%; background: {{item.color || 'var(--primary)'}};"></view>
        </view>
      </view>
    </view>

    <view wx:for="{{latestSuggestions}}" wx:key="exerciseId" class="suggestion-card">
      <view class="suggestion-head">
        <view class="suggestion-name">{{item.exerciseName}}</view>
        <view class="suggestion-action {{item.action}}">{{item.actionLabel || '训练建议'}}</view>
      </view>
      <view wx:if="{{item.targetText}}" class="suggestion-target">下次目标：{{item.targetText}}</view>
      <view wx:if="{{item.reason}}" class="suggestion-reason">依据：{{item.reason}}</view>
      <view class="suggestion-advice">{{item.advice}}</view>
    </view>
  </block>
  <block wx:else>
    <view class="card block report-empty">
      <view class="muted">所选日期无训练记录</view>
    </view>
  </block>

  <!-- 体重趋势 -->
  <view class="card block">
    <view class="section-header-row">
      <view class="section-title">体重趋势</view>
      <view class="bmi-badge {{bmiCategory}}" wx:if="{{latestWeightRecord && heightCm && bmi}}">
        BMI {{bmi}} · {{bmiText}}
      </view>
      <view class="bmi-badge bmi-empty" bindtap="goProfile" wx:if="{{latestWeightRecord && !heightCm}}">
        去设置身高计算 BMI >
      </view>
    </view>
    <view class="weight-bars" wx:if="{{chartWeights.length > 0}}">
      <view wx:for="{{chartWeights}}" wx:key="date" class="weight-bar-wrapper">
        <view class="weight-bar-val">{{item.weightKg}}</view>
        <view class="weight-bar" style="height: {{item.height}}rpx;"></view>
        <view class="weight-bar-date">{{item.displayDate}}</view>
      </view>
    </view>
    <view class="weight-empty" wx:else>
      <view class="muted">暂无体重数据，请在下方记录今日体重</view>
    </view>
  </view>

  <!-- 今日体重记录 -->
  <view class="weight-row">
    <input class="weight-input" type="digit" value="{{weightKg}}" bindinput="onWeightInput" placeholder="今日体重 kg" />
    <button class="primary-button save-button" bindtap="saveWeight">保存</button>
  </view>
</view>
