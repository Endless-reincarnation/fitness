.page {
  padding: 48rpx 28rpx 32rpx;
}

.report-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.report-title {
  margin-top: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.05;
}

.next-card {
  margin-bottom: 28rpx;
  padding: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 14rpx;
  background: var(--primary);
  color: var(--button-text);
}

.next-label {
  font-size: 24rpx;
  font-weight: 900;
}

.next-title {
  margin-top: 34rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.05;
}

.next-text {
  margin-top: 28rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.weight-row {
  display: grid;
  grid-template-columns: 1fr 180rpx;
  gap: 16rpx;
  margin-top: 20rpx;
}

.weight-input {
  height: 88rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: var(--card-strong);
  color: var(--text);
  border: 2rpx solid var(--border);
  font-size: 30rpx;
}

.save-button {
  height: 88rpx;
  line-height: 88rpx;
}

.block {
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.empty {
  margin-top: 18rpx;
}

.muscle-row {
  margin-top: 24rpx;
}

.muscle-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.muscle-percent {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 800;
}

.bar {
  height: 24rpx;
  margin-top: 12rpx;
  border-radius: 6rpx;
  background: var(--primary-fade-12);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.bmi-badge {
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.bmi-empty {
  border: 2rpx dashed var(--primary);
  color: var(--primary);
  background: var(--primary-fade-5);
}

.bmi-normal {
  border: 2rpx solid var(--primary);
  color: var(--primary);
  background: var(--primary-fade-8);
}

.bmi-underweight {
  border: 2rpx solid var(--muted);
  color: var(--muted);
  background: rgba(255, 255, 255, 0.05);
}

.bmi-overweight {
  border: 2rpx solid var(--primary-strong);
  color: var(--primary-strong);
  background: rgba(245, 158, 11, 0.08);
}

.bmi-obese {
  border: 2rpx solid var(--danger);
  color: var(--danger);
  background: rgba(255, 81, 72, 0.08);
}

.weight-bars {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  height: 180rpx;
  margin-top: 28rpx;
}

.weight-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.weight-bar-val {
  font-size: 20rpx;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.weight-bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  background: var(--primary);
  opacity: 0.85;
}

.weight-bar-date {
  font-size: 18rpx;
  color: var(--muted);
  margin-top: 10rpx;
  white-space: nowrap;
}

.weight-empty {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.suggestion-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card);
  color: var(--text);
  font-size: 26rpx;
  font-weight: 900;
}

/* 日历卡片 */
.calendar-card {
  padding: 24rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.calendar-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 900;
}

.calendar-month {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text);
}

.weekday-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 12rpx;
  text-align: center;
}

.weekday-label {
  font-size: 20rpx;
  color: var(--muted);
  font-weight: 800;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  row-gap: 16rpx;
  column-gap: 12rpx;
  text-align: center;
}

.day-cell {
  position: relative;
  height: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  transition: all 0.1s ease;
}

.day-cell.blank {
  background: transparent;
}

.day-cell:not(.blank):active {
  background: var(--primary-fade-12);
}

.day-num {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--text);
}

.day-cell.today {
  border: 2rpx solid var(--primary);
}

.day-cell.selected {
  background: var(--primary) !important;
}

.day-cell.selected .day-num {
  color: var(--button-text);
}

.day-cell.selected .workout-dot {
  background: var(--button-text);
}

.workout-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary);
  position: absolute;
  bottom: 8rpx;
}

/* 布局辅助 */
.block-margin {
  margin-top: 36rpx;
}

.muted-stats {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 800;
  margin-top: 10rpx;
}

/* 空状态样式 */
.report-empty {
  padding: 60rpx 0;
  text-align: center;
  color: var(--muted);
  font-size: 26rpx;
}

/* 折叠展开切换栏 */
.calendar-toggle {
  margin-top: 18rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid var(--border);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 800;
}

.toggle-icon {
  font-size: 18rpx;
}
