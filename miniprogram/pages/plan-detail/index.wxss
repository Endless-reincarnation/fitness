.page {
  padding: 48rpx 28rpx calc(180rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.plan-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.12;
}

.tags {
  margin-top: 16rpx;
}

.ai-note-card {
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.ai-note-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.ai-note-text {
  margin-top: 14rpx;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.5;
}

.ai-note-section {
  margin-top: 20rpx;
}

.ai-note-title {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 900;
}

.ai-note-line {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.day-card {
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.day-title {
  margin-bottom: 10rpx;
  color: var(--text);
  font-size: 34rpx;
  font-weight: 900;
}

.exercise-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border: 3rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card-strong);
}

.mark {
  width: 10rpx;
  height: 48rpx;
  margin-right: 20rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.exercise-main {
  flex: 1;
}

.exercise-name {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 900;
}

.exercise-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.role-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.bottom-action-area {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(to top, var(--bg) 75%, transparent);
  z-index: 90;
}

.action-grid {
  display: grid;
  grid-template-columns: 0.82fr 1fr;
  gap: 18rpx;
}

.fixed-action {
  margin-top: 0;
  margin-bottom: 0;
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.custom-action-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.custom-action-row .ghost-button {
  flex: 1;
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  margin: 0;
  padding: 0;
}

.custom-action-row .delete-btn {
  color: var(--danger) !important;
  border-color: var(--danger) !important;
}

.secondary-action {
  font-size: 30rpx;
}
