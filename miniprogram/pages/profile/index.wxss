.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 2rpx solid var(--primary);
  background: var(--card-strong);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--primary);
  color: var(--button-text);
  text-align: center;
  line-height: 96rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.profile-info {
  flex-grow: 1;
}

.name {
  font-size: 34rpx;
  font-weight: 800;
}

.edit-icon {
  font-size: 32rpx;
  color: var(--primary);
  opacity: 0.8;
  padding: 10rpx;
}

.block {
  margin: 24rpx 0;
}

.plan-text {
  margin-top: 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-value {
  margin-top: 14rpx;
  font-size: 44rpx;
  font-weight: 900;
  color: var(--primary);
}

.theme-row {
  margin-top: 22rpx;
  display: flex;
  gap: 16rpx;
}

.theme-option {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 800;
}

.theme-option.active {
  border-color: var(--primary);
  color: var(--text);
}

.theme-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.theme-dot.power-yellow {
  background: #ffd23f;
}

.theme-dot.tech-green {
  background: #20f0a0;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-arrow {
  color: var(--primary);
  font-size: 54rpx;
  font-weight: 900;
}

/* ==================== 模态弹窗 Modal 样式 ==================== */
.modal-backdrop {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12rpx);
  display: flex;
  align-items: flex-end; /* 从底部拉出 */
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.modal-backdrop.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 100%;
  background: var(--surface);
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  border-top: 2rpx solid var(--border);
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  max-height: 85vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.modal-backdrop.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--text);
}

.modal-close {
  font-size: 48rpx;
  color: var(--muted);
  padding: 10rpx;
  line-height: 1;
}

.modal-body {
  max-height: 55vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 84rpx;
  background: var(--card-strong);
  border: 2rpx solid var(--border);
  color: var(--text);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary);
  color: var(--button-text);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

/* ==================== 个人资料表单行样式 ==================== */
.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-btn {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  border: 4rpx dashed var(--border);
  background: var(--card-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 44rpx;
  color: var(--primary);
  font-weight: 900;
  line-height: 1;
}

.avatar-placeholder .text {
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 6rpx;
  font-weight: 800;
}

.hint {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 16rpx;
  text-align: center;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  font-size: 26rpx;
  color: var(--muted);
  font-weight: 800;
  margin-bottom: 14rpx;
}

.form-input, .picker-value {
  width: 100%;
  height: 88rpx;
  line-height: 84rpx;
  background: var(--card-strong);
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  padding: 0 24rpx;
  color: var(--text);
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  position: relative;
}

.picker-value::after {
  content: '›';
  position: absolute;
  right: 24rpx;
  color: var(--muted);
  font-size: 40rpx;
}
