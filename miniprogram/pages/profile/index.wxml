<view class="page theme-{{theme}}" style="{{customThemeStyle}}">
  <!-- 用户名片区域 (点击可弹窗编辑资料) -->
  <view class="card profile-card" bindtap="openEditModal">
    <image wx:if="{{userProfile && userProfile.avatar_url}}" class="avatar-img" src="{{userProfile.avatar_url}}" mode="aspectFill"></image>
    <view wx:else class="avatar">{{avatarFallback}}</view>
    <view class="profile-info">
      <view class="name">{{userProfile && userProfile.nickname ? userProfile.nickname : '训练用户'}}</view>
      <view class="muted">{{userProfile && userProfile.nickname ? '同步微信身份已生效' : '点击完善个人资料与登录'}}</view>
    </view>
    <view class="edit-icon">✎</view>
  </view>

  <view class="card block">
    <view class="section-title">当前计划</view>
    <view class="muted plan-text">{{activePlan ? activePlan.name : '暂无启用计划'}}</view>
  </view>

  <view class="grid">
    <view class="card stat-card">
      <view class="muted">训练次数</view>
      <view class="stat-value">{{workoutCount}}</view>
    </view>
    <view class="card stat-card">
      <view class="muted">体重记录</view>
      <view class="stat-value">{{weightCount}}</view>
    </view>
  </view>

  <view class="card block action-card" bindtap="openExercises">
    <view>
      <view class="section-title">动作库</view>
      <view class="muted plan-text">查看动作步骤、目标肌群和常见错误</view>
    </view>
    <view class="action-arrow">›</view>
  </view>

  <view class="card block action-card" bindtap="openFeedbackModal">
    <view>
      <view class="section-title">建议留言</view>
      <view class="muted plan-text">告诉我们哪里不好用，或者想加什么功能</view>
    </view>
    <view class="action-arrow">›</view>
  </view>

  <view wx:if="{{isAdmin}}" class="card block action-card" bindtap="openCloudDiagnostics">
    <view>
      <view class="section-title">云数据诊断</view>
      <view class="muted plan-text">检查集合数量、云端读写和待同步记录</view>
    </view>
    <view class="action-arrow">&gt;</view>
  </view>

  <view class="card block">
    <view class="section-title">训练皮肤</view>
    <view class="theme-row">
      <view wx:for="{{themeOptions}}" wx:key="value" class="theme-option {{theme === item.value ? 'active' : ''}}" data-theme="{{item.value}}" bindtap="switchTheme">
        <view class="theme-dot {{item.value}}"></view>
        <view>{{item.label}}</view>
      </view>
    </view>
    <view class="custom-theme-panel">
      <view class="muted custom-theme-title">自定义主色</view>
      <view class="custom-color-row">
        <view wx:for="{{customThemeColors}}" wx:key="value" class="custom-color-option {{theme === 'custom' && customPrimaryColor === item.value ? 'active' : ''}}" data-color="{{item.value}}" bindtap="switchCustomThemeColor">
          <view class="custom-color-dot" style="background: {{item.value}};"></view>
          <view>{{item.label}}</view>
        </view>
      </view>
    </view>
  </view>

  <reminder-settings theme="{{theme}}" custom-primary-color="{{customPrimaryColor}}" />

  <!-- ==================== 个人资料编辑 Modal ==================== -->
  <view class="modal-backdrop {{showEditModal ? 'show' : ''}}" bindtap="closeEditModal">
    <view class="modal-content" catchtap="noop">
      <view class="modal-header">
        <view class="modal-title">编辑个人资料</view>
        <view class="modal-close" bindtap="closeEditModal">×</view>
      </view>
      
      <scroll-view scroll-y class="modal-body">
        <!-- 头像设置 -->
        <view class="form-row avatar-row">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{tempAvatarUrl}}" class="avatar-preview" src="{{tempAvatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="avatar-placeholder">
              <view class="plus-icon">＋</view>
              <view class="text">设置头像</view>
            </view>
          </button>
          <view class="hint">点击圆框选择微信头像或上传图片</view>
        </view>

        <!-- 昵称设置 -->
        <view class="form-item">
          <view class="label">昵称</view>
          <input type="nickname" class="form-input" placeholder="请输入或一键填入微信昵称" value="{{tempNickname}}" bindblur="onNicknameBlur" bindinput="onNicknameInput" />
        </view>

        <!-- 性别选择 -->
        <view class="form-item">
          <view class="label">性别</view>
          <picker mode="selector" range="{{genderOptions}}" range-key="label" bindchange="onGenderChange">
            <view class="picker-value">
              {{selectedGenderLabel}}
            </view>
          </picker>
        </view>

        <!-- 身高设置 -->
        <view class="form-item">
          <view class="label">身高 (cm)</view>
          <input type="number" class="form-input" placeholder="例如: 175" value="{{tempHeight}}" bindinput="onHeightInput" />
        </view>

        <!-- 训练目标 -->
        <view class="form-item">
          <view class="label">训练目标</view>
          <picker mode="selector" range="{{goalOptions}}" range-key="label" bindchange="onGoalChange">
            <view class="picker-value">
              {{selectedGoalLabel}}
            </view>
          </picker>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeEditModal">取消</button>
        <button class="btn-save" bindtap="saveProfile" disabled="{{isSaving}}">
          {{isSaving ? '正在保存...' : '保存并同步'}}
        </button>
      </view>
    </view>
  </view>

  <!-- ==================== 建议留言 Modal ==================== -->
  <view class="modal-backdrop {{showFeedbackModal ? 'show' : ''}}" bindtap="closeFeedbackModal">
    <view class="modal-content" catchtap="noop">
      <view class="modal-header">
        <view class="modal-title">建议留言</view>
        <view class="modal-close" bindtap="closeFeedbackModal">×</view>
      </view>

      <view class="form-item">
        <view class="label">建议内容</view>
        <textarea class="feedback-textarea" value="{{tempFeedbackContent}}" data-field="tempFeedbackContent" bindinput="onFeedbackInput" maxlength="500" placeholder="哪里不好用，或者你希望加什么功能？" />
      </view>

      <view class="form-item">
        <view class="label">联系方式（选填）</view>
        <input class="form-input" value="{{tempFeedbackContact}}" data-field="tempFeedbackContact" bindinput="onFeedbackInput" placeholder="微信号或手机号，方便需要时联系你" />
      </view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeFeedbackModal">取消</button>
        <button class="btn-save" bindtap="submitFeedback" disabled="{{isSubmittingFeedback}}">
          {{isSubmittingFeedback ? '正在提交...' : '提交建议'}}
        </button>
      </view>
    </view>
  </view>
</view>
