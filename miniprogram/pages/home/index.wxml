<view class="page home-page theme-{{theme}}" style="{{customThemeStyle}}">
  <view wx:if="{{!activePlan}}" class="card block">
    <view class="eyebrow">TODAY PROGRAM</view>
    <view class="section-title">还没有启用计划</view>
    <view class="muted block-text">先从计划库选择一套计划，之后首页会直接显示今日训练。</view>
    <button class="primary-button" bindtap="goPlans">去选择计划</button>
  </view>

  <block wx:else>
    <view wx:if="{{workoutDraft}}" class="resume-card">
      <view>
        <view class="resume-label">未完成训练</view>
        <view class="resume-title">{{workoutDraft.dayName}}</view>
        <view class="resume-sub">练到：{{workoutDraft.currentExerciseName}} · 第 {{workoutDraft.currentSetIndex + 1}} 组</view>
      </view>
      <button class="primary-button resume-button" bindtap="resumeWorkout">继续训练</button>
    </view>

    <view class="screen-header">
      <view class="eyebrow">TODAY PROGRAM</view>
      <view class="hero-title">{{heroStatusTitle}}</view>
      <view class="muted">{{heroStatusText}}</view>
      <picker mode="selector" range="{{dayOptions}}" value="{{activePlan.currentDayIndex}}" bindchange="onDayChange">
        <view class="day-picker">切换训练日</view>
      </picker>
    </view>

    <view class="card schedule-card" wx:if="{{weeklySchedule.length}}">
      <view class="schedule-title-row">
        <view class="section-title compact-title">本周安排</view>
        <view class="schedule-edit-btn" bindtap="toggleScheduleEditor">{{scheduleEditing ? '收起' : '调整'}}</view>
      </view>
      <view class="week-strip">
        <view wx:for="{{weeklySchedule}}" wx:key="dateKey" class="week-cell {{item.type}} {{item.isToday ? 'today' : ''}} {{item.isCompleted ? 'done' : ''}}">
          <view class="week-day">{{item.weekdayLabel}}</view>
          <view class="week-label">{{item.label}}</view>
        </view>
      </view>
      <view wx:if="{{scheduleEditing}}" class="schedule-editor">
        <view wx:for="{{weeklySchedule}}" wx:key="dateKey" class="schedule-edit-row">
          <view class="schedule-edit-day">周{{item.weekdayLabel}}</view>
          <view class="schedule-type-group">
            <view class="schedule-type {{item.type === 'training' ? 'active' : ''}}" data-weekday="{{item.weekday}}" data-type="training" bindtap="changeScheduleDay">训练</view>
            <view class="schedule-type {{item.type === 'rest' ? 'active' : ''}}" data-weekday="{{item.weekday}}" data-type="rest" bindtap="changeScheduleDay">休息</view>
            <view class="schedule-type {{item.type === 'flex' ? 'active' : ''}}" data-weekday="{{item.weekday}}" data-type="flex" bindtap="changeScheduleDay">灵活</view>
          </view>
        </view>
        <view class="schedule-reset" bindtap="resetSchedule">恢复默认节奏</view>
      </view>
    </view>

    <view class="card advice-card" wx:if="{{todayAdvice}}">
      <view class="advice-meta-row">
        <view class="advice-badge {{todayAdvice.type}}">{{todayAdvice.nutritionFocus.title}}</view>
        <view class="advice-next-pill" wx:if="{{todayAdvice.nextDayName}}">下次：{{todayAdvice.nextDayName}}</view>
      </view>
      <view class="advice-reason">{{todayAdvice.reason}}</view>
      <view class="nutrition-summary" bindtap="goNutrition">
        <view class="nutrition-summary-head">
          <view class="nutrition-label">饮食</view>
          <view class="nutrition-link">查看详情 ></view>
        </view>
        <view class="nutrition-text">{{todayAdvice.nutritionFocus.text}}</view>
        <view wx:if="{{nutritionPreviewItems.length}}" class="nutrition-mini-grid">
          <view wx:for="{{nutritionPreviewItems}}" wx:key="label" class="nutrition-mini-item {{item.highlight ? 'highlight' : ''}}">
            <view class="nutrition-mini-value">{{item.value}}</view>
            <view class="nutrition-mini-unit">{{item.unit}}</view>
            <view class="nutrition-mini-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="lift-card">
      <view class="lift-label">当前动作</view>
      <view class="lift-name">{{firstExercise.detail.name}}</view>
      <view class="lift-meta">{{firstExercise.sets}} 组 · {{firstExercise.reps}} 次 · RPE {{firstExercise.rpe}} · REST {{firstExercise.restSeconds}}s</view>
    </view>

    <view class="grid">
      <view class="card stat-card">
        <view class="stat-label">本周目标</view>
        <view class="stat-value">{{weeklyProgressText}}</view>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{weeklyProgressPercent}}%;"></view>
        </view>
      </view>
      <view class="card stat-card">
        <view class="stat-label">下次训练</view>
        <view class="stat-value small">{{nextDayName}}</view>
      </view>
    </view>

    <view class="section-title list-title">动作清单</view>
    <view class="exercise-list">
      <view wx:for="{{todayDay.exercises}}" wx:key="exerciseId" class="exercise-row">
        <view class="mark"></view>
        <view class="exercise-main">
          <view class="exercise-name">{{item.detail.name}}</view>
          <view class="exercise-sub">{{item.sets}} 组 · {{item.reps}} 次 · 休 {{item.restSeconds}} 秒</view>
        </view>
        <view class="sets-label">{{item.sets}} 组</view>
      </view>
    </view>
    <view class="bottom-action-area">
      <button class="primary-button start-button" bindtap="startWorkout">{{startButtonText}}</button>
    </view>
  </block>
</view>
