.home-page {
  padding: 48rpx 28rpx calc(180rpx + env(safe-area-inset-bottom));
}

.hero-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.screen-header {
  margin-bottom: 32rpx;
}

.resume-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
  padding: 24rpx;
  border: 4rpx solid var(--primary);
  border-radius: 14rpx;
  background: var(--primary-fade-6);
}

.resume-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.resume-title {
  margin-top: 8rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
}

.resume-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.resume-button {
  flex: 0 0 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
}

.day-picker {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 14rpx 20rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--primary);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.block {
  margin-bottom: 24rpx;
}

.block-text {
  margin: 16rpx 0 24rpx;
}

.schedule-card,
.advice-card {
  margin-bottom: 28rpx;
  border-radius: 14rpx;
}

.schedule-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.compact-title {
  font-size: 30rpx;
}

.schedule-edit-btn {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border: 2rpx solid var(--primary);
  border-radius: 8rpx;
  color: var(--primary);
  background: var(--primary-fade-5);
  font-size: 22rpx;
  font-weight: 900;
}

.week-strip {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.week-cell {
  min-height: 104rpx;
  padding: 12rpx 8rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
  box-sizing: border-box;
  text-align: center;
}

.week-cell.training {
  border-color: var(--primary-fade-34);
}

.week-cell.rest {
  opacity: 0.72;
}

.week-cell.flex {
  border-style: dashed;
}

.week-cell.today {
  border-color: var(--primary);
  background: var(--primary-fade-12);
}

.week-cell.done {
  background: var(--primary);
  border-color: var(--primary);
}

.week-day {
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 900;
}

.week-cell.done .week-day,
.week-cell.done .week-label {
  color: var(--button-text);
}

.week-label {
  margin-top: 10rpx;
  color: var(--text);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.25;
  word-break: break-all;
}

.schedule-editor {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border);
}

.schedule-edit-row {
  display: grid;
  grid-template-columns: 72rpx 1fr;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.schedule-edit-day {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.schedule-type-group {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.schedule-type {
  height: 54rpx;
  line-height: 54rpx;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  background: var(--card-strong);
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
}

.schedule-type.active {
  border-color: var(--primary);
  background: var(--primary);
  color: var(--button-text);
}

.schedule-reset {
  margin-top: 18rpx;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
  text-align: center;
}

.advice-card {
  padding: 26rpx;
  border: 3rpx solid var(--primary);
  background:
    linear-gradient(135deg, var(--primary-fade-12), transparent 62%),
    var(--card);
}

.advice-meta-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.advice-badge {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--border);
  background: var(--card-strong);
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.advice-badge.training {
  color: var(--primary);
  border-color: var(--primary);
  background: var(--primary-fade-8);
}

.advice-badge.rest {
  color: var(--muted);
}

.advice-badge.optional {
  color: var(--primary-strong);
  border-color: var(--primary-strong);
  background: rgba(245, 158, 11, 0.08);
}

.advice-next-pill {
  min-width: 0;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
}

.advice-reason {
  margin-top: 24rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.nutrition-summary {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border);
}

.nutrition-summary:active {
  opacity: 0.78;
}

.nutrition-summary-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.nutrition-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.nutrition-link {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.nutrition-text {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
}

.nutrition-mini-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.nutrition-mini-item {
  min-height: 96rpx;
  padding: 14rpx 8rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
  box-sizing: border-box;
  text-align: center;
}

.nutrition-mini-item.highlight {
  border-color: var(--primary);
}

.nutrition-mini-value {
  display: inline;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.nutrition-mini-unit {
  display: inline;
  margin-left: 4rpx;
  color: var(--primary);
  font-size: 18rpx;
  font-weight: 900;
}

.nutrition-mini-label {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 800;
}

.lift-card {
  margin-bottom: 28rpx;
  padding: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 14rpx;
  background: var(--primary);
  color: var(--button-text);
}

.lift-label {
  font-size: 24rpx;
  font-weight: 900;
}

.lift-name {
  margin-top: 36rpx;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.05;
}

.lift-meta {
  margin-top: 28rpx;
  font-size: 26rpx;
  font-weight: 900;
}

.list-title {
  margin: 34rpx 0 20rpx;
}

.exercise-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  margin-bottom: 22rpx;
  padding: 0 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card-strong);
  font-size: 28rpx;
}

.mark {
  width: 10rpx;
  height: 48rpx;
  margin-right: 24rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.exercise-name {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 900;
}

.exercise-main {
  flex: 1;
}

.exercise-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.sets-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.stat-card {
  min-height: 144rpx;
  border-radius: 12rpx;
}

.stat-value {
  margin-top: 14rpx;
  color: var(--text);
  font-size: 44rpx;
  font-weight: 900;
}

.progress-track {
  overflow: hidden;
  height: 12rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: var(--border);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--primary);
}

.stat-value.small {
  font-size: 30rpx;
  line-height: 1.25;
}

.stat-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.bottom-action-area {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 24rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(to top, var(--bg) 75%, transparent);
  z-index: 90;
}

.start-button {
  margin-top: 0;
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}
