.page {
  padding: 48rpx 28rpx 32rpx;
}

.workout-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.day-title {
  margin-top: 18rpx;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.05;
}

.workout-card {
  margin-bottom: 28rpx;
  border: 4rpx solid var(--primary);
  border-radius: 14rpx;
}

.set-label {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.live-number-row {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  margin: 42rpx 0 26rpx;
}

.live-number {
  color: var(--text);
  font-size: 76rpx;
  font-weight: 900;
  line-height: 0.9;
}

.unit {
  color: var(--primary);
  font-size: 34rpx;
  font-weight: 900;
}

.live-meta {
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 900;
}

.target {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: var(--primary-fade-6);
  border: 4rpx solid var(--primary);
  font-size: 28rpx;
  line-height: 1.7;
}

.rule-title {
  margin-bottom: 12rpx;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 900;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.field-box {
  min-height: 168rpx;
  padding: 16rpx;
  border: 3rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card-strong);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.field-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.input {
  height: 58rpx;
  padding: 0;
  background: transparent;
  color: var(--text);
  border: 0;
  font-size: 34rpx;
  font-weight: 900;
}

.quick-adjust-row {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 10rpx;
}

.adjust-btn {
  flex: 1;
  height: 42rpx;
  line-height: 42rpx;
  background: var(--border);
  color: var(--text);
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
  border-radius: 6rpx;
  transition: all 0.1s ease;
}

.adjust-btn:active {
  background: var(--primary);
  color: var(--button-text);
}

.rest-card {
  margin-bottom: 28rpx;
  border-radius: 12rpx;
  text-align: center;
}

.rest-time {
  margin: 16rpx 0 10rpx;
  font-size: 86rpx;
  font-weight: 900;
  color: var(--primary);
}

.rest-label {
  text-align: left;
  font-size: 24rpx;
  font-weight: 900;
}

.rest-bars {
  display: flex;
  gap: 8rpx;
  margin-top: 18rpx;
}

.rest-bar {
  flex: 1;
  height: 20rpx;
  border-radius: 5rpx;
  background: var(--primary-fade-12);
}

.rest-bar.on {
  background: var(--primary);
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  width: 100%;
  margin-top: 20rpx;
}

.quick-button,
.done-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.last-workout-info {
  margin-bottom: 28rpx;
  padding: 18rpx 24rpx;
  border-radius: 12rpx;
  background: var(--card-strong);
  border: 2rpx dashed var(--border);
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.last-workout-label {
  color: var(--muted);
}

.last-workout-value {
  color: var(--text);
  font-weight: 700;
}

.exercise-guide-panel {
  margin-top: 40rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  padding: 32rpx;
  box-shadow: 0 18rpx 40rpx rgba(0, 0, 0, 0.28);
}

.guide-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--primary);
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 16rpx;
}

.guide-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.guide-meta-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.guide-meta-item {
  display: flex;
  font-size: 26rpx;
  line-height: 1.5;
}

.guide-meta-label {
  color: var(--muted);
  width: 140rpx;
  flex-shrink: 0;
}

.guide-meta-val {
  color: var(--text);
  font-weight: 700;
}

.guide-rules {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.guide-rule-item {
  margin-bottom: 16rpx;
}

.guide-rule-item:last-child {
  margin-bottom: 0;
}

.guide-rule-label {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.guide-rule-content {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.6;
}

.guide-section {
  margin-top: 24rpx;
}

.guide-section-header {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--text);
  margin-bottom: 16rpx;
}

.guide-step-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.guide-step-row:last-child {
  margin-bottom: 0;
}

.guide-step-index {
  background: var(--border);
  color: var(--text);
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.guide-step-text {
  color: var(--text);
  flex: 1;
}

.guide-mistake-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.guide-mistake-row:last-child {
  margin-bottom: 0;
}

.guide-mistake-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--danger);
  margin-right: 18rpx;
  flex-shrink: 0;
  margin-top: 14rpx;
}

.guide-mistake-text {
  color: var(--text);
  flex: 1;
}

