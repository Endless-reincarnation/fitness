.page {
  padding: 48rpx 28rpx 32rpx;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.exercise-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.lift-card {
  margin-bottom: 28rpx;
  padding: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 14rpx;
  background: var(--primary);
  color: var(--button-text);
}

.lift-label {
  font-size: 24rpx;
  font-weight: 900;
}

.lift-name {
  margin-top: 28rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.lift-meta {
  margin-top: 22rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.block {
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.performance-card {
  border: 3rpx solid var(--primary);
  background:
    linear-gradient(135deg, var(--primary-fade-12), transparent 62%),
    var(--card);
}

.performance-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 24rpx;
}

.performance-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 800;
}

.performance-main {
  margin-top: 10rpx;
  color: var(--primary);
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.performance-date {
  flex-shrink: 0;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 800;
}

.performance-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 26rpx;
}

.performance-item {
  padding: 18rpx;
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
}

.performance-value {
  color: var(--text);
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.performance-suggestion {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  background: var(--primary-fade-8);
  border: 2rpx solid var(--primary);
}

.suggestion-title {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.suggestion-target,
.suggestion-text {
  margin-top: 12rpx;
  color: var(--text);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.55;
}

.suggestion-target {
  color: var(--muted);
}

.step-row {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.step-index {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary);
  color: var(--button-text);
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.step-text {
  flex: 1;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.mistake-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
  border-bottom: 2rpx solid var(--border);
}

.mark {
  width: 10rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: var(--primary);
}
