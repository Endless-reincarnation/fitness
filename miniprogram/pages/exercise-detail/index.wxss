.page {
  padding: 48rpx 28rpx 32rpx;
}

.header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.exercise-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.lift-card {
  margin-bottom: 28rpx;
  padding: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 14rpx;
  background: var(--primary);
  color: var(--button-text);
}

.lift-label {
  font-size: 24rpx;
  font-weight: 900;
}

.lift-name {
  margin-top: 28rpx;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.lift-meta {
  margin-top: 22rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.block {
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.step-row {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.step-index {
  flex: 0 0 44rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary);
  color: var(--button-text);
  text-align: center;
  line-height: 44rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.step-text {
  flex: 1;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
}

.mistake-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 700;
  border-bottom: 2rpx solid var(--border);
}

.mark {
  width: 10rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: var(--primary);
}
