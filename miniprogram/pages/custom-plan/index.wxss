.page {
  padding: 48rpx 28rpx 32rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.page-title {
  margin-top: 18rpx;
  margin-bottom: 18rpx;
  color: var(--text);
  font-size: 64rpx;
  font-weight: 900;
  line-height: 1.12;
}

.intro {
  line-height: 1.5;
}

.block {
  margin-bottom: 26rpx;
  border-radius: 12rpx;
}

.field-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
}

.field-label.second {
  margin-top: 24rpx;
}

.day-tabs {
  margin-top: 20rpx;
  white-space: nowrap;
}

.day-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 22rpx;
  margin-right: 14rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.day-tab.active {
  border-color: var(--primary);
  color: var(--button-text);
  background: var(--primary);
}

.add-day-tab {
  border-style: dashed;
  color: var(--primary);
}

.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.field-label-row.second {
  margin-top: 24rpx;
}

.delete-day-link {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
}

.input,
.mini-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 78rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
}

.field-box {
  min-width: 0;
}

.mini-input {
  text-align: center;
}

.add-button {
  margin-top: 22rpx;
  border-radius: 10rpx;
}

.selected-exercise {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
  padding: 22rpx 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
}

.selected-exercise.active {
  border-color: var(--primary);
  background: var(--primary-fade-8);
}

.selected-label {
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 900;
}

.selected-name {
  margin-top: 8rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
}

.selected-action {
  flex: 0 0 auto;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  color: var(--button-text);
  background: var(--primary);
  font-size: 24rpx;
  font-weight: 900;
}

.create-exercise-button {
  margin-top: 14rpx;
  border-radius: 10rpx;
}

.picker-backdrop {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.72);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
  z-index: 200;
}

.picker-backdrop.show {
  opacity: 1;
  pointer-events: auto;
}

.picker-sheet {
  width: 100%;
  max-height: 78vh;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  border: 3rpx solid var(--border);
  background: var(--bg);
  box-sizing: border-box;
}

.sheet-handle {
  width: 78rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: var(--border);
}

.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-title {
  color: var(--text);
  font-size: 36rpx;
  font-weight: 900;
}

.sheet-subtitle {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.sheet-close {
  color: var(--primary);
  font-size: 48rpx;
  font-weight: 900;
}

.picker-search {
  box-sizing: border-box;
  width: 100%;
  min-height: 78rpx;
  margin-top: 24rpx;
  padding: 0 18rpx;
  border: 3rpx solid var(--border);
  border-radius: 10rpx;
  background: var(--card-strong);
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
}

.region-tabs {
  margin-top: 18rpx;
  white-space: nowrap;
}

.region-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84rpx;
  height: 54rpx;
  margin-right: 12rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 999rpx;
  color: var(--muted);
  background: var(--card-strong);
  font-size: 24rpx;
  font-weight: 900;
}

.region-tab.active {
  color: var(--button-text);
  border-color: var(--primary);
  background: var(--primary);
}

.picker-list {
  max-height: 450rpx;
  margin-top: 18rpx;
}

.picker-exercise-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 96rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  margin-bottom: 14rpx;
  background: var(--card-strong);
}

.picker-exercise-name {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 900;
}

.picker-exercise-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.picker-check {
  width: 36rpx;
  color: var(--primary);
  font-size: 32rpx;
  font-weight: 900;
  text-align: right;
}

.picker-empty {
  padding: 46rpx 24rpx;
  color: var(--muted);
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
}

.list-title {
  margin: 30rpx 0 18rpx;
}

.empty {
  margin-bottom: 20rpx;
}

.exercise-row {
  display: flex;
  align-items: flex-start;
  min-height: 96rpx;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 12rpx;
  background: var(--card-strong);
}

.mark {
  width: 10rpx;
  height: 48rpx;
  margin-top: 8rpx;
  margin-right: 24rpx;
  border-radius: 999rpx;
  background: var(--primary);
}

.exercise-main {
  flex: 1;
  min-width: 0;
}

.exercise-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.exercise-title-copy {
  flex: 1;
  min-width: 0;
}

.exercise-name {
  color: var(--text);
  font-size: 28rpx;
  font-weight: 900;
}

.exercise-sub {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 700;
}

.exercise-edit-row {
  display: grid;
  grid-template-columns: 0.7fr 1fr 0.8fr;
  gap: 10rpx;
  margin-top: 14rpx;
}

.exercise-edit-box {
  display: flex;
  align-items: center;
  min-width: 0;
  border: 2rpx solid var(--border);
  border-radius: 8rpx;
  background: var(--bg);
  overflow: hidden;
}

.exercise-edit-label {
  flex: 0 0 42rpx;
  color: var(--primary);
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
}

.exercise-edit-input {
  flex: 1;
  min-width: 0;
  height: 54rpx;
  padding: 0 8rpx;
  color: var(--text);
  font-size: 24rpx;
  font-weight: 800;
}

.row-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 8rpx;
}

.icon-action {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--primary-fade-34);
  border-radius: 10rpx;
  background: var(--primary-fade-8);
}

.action-icon {
  color: var(--muted);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 900;
}

.remove-action .action-icon {
  color: var(--primary);
}

.move-action.disabled {
  opacity: 0.35;
}

.save-button {
  margin-top: 26rpx;
  border-radius: 10rpx;
}

/* AI 描述卡片与膳食建议卡片样式 */
.ai-note-card {
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.ai-note-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.ai-note-text {
  margin-top: 14rpx;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.5;
}

.ai-note-section {
  margin-top: 20rpx;
}

.ai-note-title {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 900;
}

.ai-note-line {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.nutrition-card {
  margin-bottom: 24rpx;
  border-radius: 12rpx;
}

.nutrition-label {
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.nutrition-title {
  margin-top: 6rpx;
  color: var(--text);
  font-size: 30rpx;
  font-weight: 900;
}

.nutrition-title .click-hint {
  font-size: 20rpx;
  color: var(--muted);
  font-weight: normal;
  margin-left: 8rpx;
}

.nutrition-custom-hint {
  font-size: 20rpx;
  color: var(--primary);
  margin-top: 10rpx;
  display: inline-block;
  background: var(--primary-fade-6);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  border: 1rpx solid var(--primary-fade-15);
  font-weight: bold;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
  margin-bottom: 24rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  background: var(--card-strong);
  border: 2rpx solid var(--border);
  border-radius: 10rpx;
  transition: transform 0.1s ease, opacity 0.1s ease;
}

.nutrition-item-active {
  opacity: 0.7;
  transform: scale(0.95);
}

.nutrition-item.highlight {
  border-color: var(--primary);
}

.nutrition-item .num {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--text);
  line-height: 1;
}

.nutrition-item.highlight .num {
  color: var(--primary);
}

.nutrition-item .unit {
  font-size: 18rpx;
  color: var(--muted);
  margin-top: 4rpx;
  font-weight: bold;
}

.nutrition-item .label {
  font-size: 18rpx;
  color: var(--muted);
  margin-top: 8rpx;
}

.nutrition-tips {
  border-top: 2rpx solid var(--border);
  padding-top: 18rpx;
}

.nutrition-tip-item {
  display: flex;
  margin-bottom: 8rpx;
}

.nutrition-tip-item:last-child {
  margin-bottom: 0;
}

.nutrition-tip-item .dot {
  color: var(--primary);
  font-weight: 900;
  margin-right: 12rpx;
  font-size: 24rpx;
}

.nutrition-tip-item .tip-text {
  flex: 1;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.4;
}

/* 营养估算弹窗样式 */
.nutrition-modal-backdrop {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.78);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
  z-index: 400;
}

.nutrition-modal-backdrop.show {
  opacity: 1;
  pointer-events: auto;
}

.nutrition-modal-card {
  box-sizing: border-box;
  width: 100%;
  max-width: 600rpx;
  padding: 36rpx;
  border: 3rpx solid var(--border);
  border-radius: 16rpx;
  background: var(--card);
  box-shadow: 0 24rpx 50rpx rgba(0, 0, 0, 0.6);
}

.nutrition-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-bottom: 2rpx solid var(--border);
  padding-bottom: 18rpx;
}

.nutrition-modal-title {
  color: var(--primary);
  font-size: 34rpx;
  font-weight: 900;
}

.nutrition-modal-close {
  color: var(--muted);
  font-size: 44rpx;
  font-weight: 900;
}

.nutrition-modal-content {
  padding: 24rpx 0;
}

.nutrition-modal-eq-title {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.nutrition-modal-eq-body {
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 700;
  white-space: pre-wrap;
  display: block;
}

.nutrition-modal-eq-hint {
  margin-top: 24rpx;
  color: var(--muted);
  font-size: 20rpx;
  line-height: 1.4;
  opacity: 0.8;
}

.nutrition-modal-btn {
  width: 100% !important;
  height: 80rpx;
  line-height: 80rpx;
  margin-top: 12rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
}
