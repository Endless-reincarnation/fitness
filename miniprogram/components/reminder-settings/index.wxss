.block {
  margin: 24rpx 0;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.setting-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.setting-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 900;
}

.setting-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.setting-column {
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.intensity-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.intensity-option {
  height: 68rpx;
  line-height: 64rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  border-radius: 12rpx;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 900;
}

.intensity-option.active {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--card-strong);
}

.reminder-test-button {
  margin-top: 24rpx;
  height: 76rpx;
  line-height: 72rpx;
  border: 2rpx solid var(--primary);
  border-radius: 12rpx;
  background: transparent;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 900;
}

.reminder-test-button::after {
  border: none;
}
