    ],
    "difficulty": "beginner",
    "movement_pattern": "pull",
    "steps": [
      "坐稳并固定大腿。",
      "双手对握把手，肩胛下沉。",
      "将把手拉向上胸区域。",
      "控制回放到手臂伸展但不耸肩。"
    ],
    "common_mistakes": [
      "身体后仰过多。",
      "拉到腹部导致轨迹偏移。",
      "顶部完全放松耸肩。"
    ],
    "safety_tips": [
      "保持胸椎自然伸展。",
      "肩部不适时缩小动作幅度。"
