      "绳索"
    ],
    "difficulty": "beginner",
    "movement_pattern": "pull",
    "steps": [
      "单手握住绳索把手。",
      "身体保持稳定，肩胛先下沉。",
      "将手肘向身体侧后方拉下。",
      "控制还原并保持背阔肌张力。"
    ],
    "common_mistakes": [
      "用手臂硬拉。",
      "耸肩。",
      "身体过度旋转。"
    ],
    "safety_tips": [
      "先用轻重量找背部发力。",
      "避免为了追重量牺牲动作幅度。"
    ],
