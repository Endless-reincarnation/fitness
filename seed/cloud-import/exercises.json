    ],
    "secondary_muscles": [],
    "equipment_tags": [
      "杠铃",
      "卧推凳"
    ],
    "difficulty": "beginner",
    "movement_pattern": "elbow_extension",
    "steps": [
      "仰卧在训练凳上，双手握杠。",
      "上臂保持相对固定。",
      "屈肘让杠铃向额头或头后下降。",
      "收缩肱三头肌伸直手臂。"
    ],
    "common_mistakes": [
      "上臂大幅摆动。",
      "使用过大重量。",
      "手腕不稳。"
    ],
    "safety_tips": [
      "建议从轻重量开始。",
      "肘部不适时改用绳索下压。"
