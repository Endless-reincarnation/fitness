    "name": "Y 字侧平举",
    "aliases": [
      "Y 字平举",
      "Y Raise"
    ],
    "primary_muscles": [
      "middle_deltoid"
    ],
    "secondary_muscles": [
      "anterior_deltoid"
    ],
    "equipment_tags": [
      "哑铃"
    ],
    "difficulty": "beginner",
    "movement_pattern": "shoulder_abduction",
    "steps": [
      "双手持轻哑铃，身体保持稳定。",
      "手臂沿身体斜前方抬起形成 Y 字轨迹。",
      "抬到肩部舒适高度后短暂停顿。",
      "控制下放回起始位置。"
    ],
    "common_mistakes": [
      "耸肩借力。",
      "身体后仰甩动。",
      "重量过大导致轨迹变形。"
    ],
    "safety_tips": [
      "使用小重量训练控制感。",
      "肩部夹痛时降低抬高手臂角度。"
