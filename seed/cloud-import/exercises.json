  {
    "_id": "parallel_bar_dip",
    "name": "双杠臂屈伸",
    "aliases": [
      "双杠臂屈伸",
      "双杠屈臂撑"
    ],
    "primary_muscles": [
      "pectoralis_major",
      "triceps_brachii"
    ],
    "secondary_muscles": [
      "anterior_deltoid"
    ],
    "equipment_tags": [
      "双杠",
      "自重"
    ],
    "difficulty": "intermediate",
    "movement_pattern": "push",
    "steps": [
      "双手撑住双杠，身体保持稳定。",
      "控制身体下降，肘部自然弯曲。",
      "下降到肩部舒适范围内。",
      "推起身体回到起始位置。"
    ],
    "common_mistakes": [
      "下降过深导致肩部不适。",
      "身体晃动。",
      "耸肩完成动作。"
    ],
    "safety_tips": [
      "无法稳定完成时先做辅助双杠或窄距俯卧撑。",
      "肩前侧疼痛时停止动作。"
    ],
