  {
    "_id": "incline_dumbbell_press",
    "name": "哑铃上斜卧推",
    "aliases": [
      "上斜哑铃卧推",
      "上胸哑铃推"
    ],
    "primary_muscles": [
      "upper_pectoralis"
    ],
    "secondary_muscles": [
      "anterior_deltoid",
      "triceps_brachii"
    ],
    "equipment_tags": [
      "哑铃",
      "上斜凳"
    ],
    "difficulty": "beginner",
    "movement_pattern": "push",
    "steps": [
      "将训练凳调到上斜角度。",
      "双手持哑铃，肩胛保持稳定。",
      "控制哑铃下降到胸上部两侧。",
      "向上推起哑铃，顶部不要猛烈碰撞。"
    ],
    "common_mistakes": [
      "凳子角度过高导致肩部代偿。",
      "手腕后折。",
      "下降过快。"
    ],
    "safety_tips": [
      "优先使用可控重量。",
      "肩部不适时降低凳子角度。"
    ],
