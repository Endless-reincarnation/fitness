[
  {
    "_id": "barbell_bench_press",
    "name": "杠铃卧推",
    "aliases": [
      "卧推",
      "平板杠铃卧推"
    ],
    "primary_muscles": [
      "pectoralis_major"
    ],
    "secondary_muscles": [
      "anterior_deltoid",
      "triceps_brachii"
    ],
    "equipment_tags": [
      "杠铃",
      "卧推凳"
    ],
    "difficulty": "beginner",
    "movement_pattern": "push",
    "steps": [
      "仰卧在卧推凳上，双脚踩稳地面。",
      "握距略宽于肩，肩胛后缩下沉。",
      "控制杠铃下降到胸部附近。",
      "保持身体稳定，将杠铃推回起始位置。"
    ],
    "common_mistakes": [
      "肩膀前顶。",
      "臀部明显离凳。",
      "杠铃下降失控。"
    ],
    "safety_tips": [
      "新手建议有人保护或使用安全架。",
      "肩部不适时降低重量或改用哑铃卧推。"
    ],
